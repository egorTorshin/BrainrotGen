APP_NAME=BrainrotGen Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Same file the worker uses when sharing ./data (see docker-compose)
SQLITE_FILE=data/app.db
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DAILY_QUOTA_SECONDS=300

# Directory where finished videos are stored (same mount as worker output, e.g. ./output or /app/output)
# MEDIA_ROOT=output
# In Docker: MEDIA_ROOT=/app/output
